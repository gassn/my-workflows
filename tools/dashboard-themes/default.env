# default テーマ (ANSI 基本 8 色、dashboard-color Spec shipped 時と同等)
# 変数名は allowlist ^COLOR_[A-Z_]+$、値は regex ^(\e\[[0-9;]+m)*$ で検証される
COLOR_COMPLETED='\e[32m'
COLOR_IN_PROGRESS='\e[33m'
COLOR_PENDING=''
COLOR_FAILED='\e[31m'
COLOR_BLOCKED='\e[35m'
COLOR_SHIPPED='\e[36m'
COLOR_ABORTED='\e[31m'
COLOR_RESET='\e[0m'
