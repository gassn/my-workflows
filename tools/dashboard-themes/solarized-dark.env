# solarized-dark テーマ (Solarized 配色、ダーク端末推奨)
# 参考: https://ethanschoonover.com/solarized/
# 高輝度 (明るめ) の ANSI コード (9x/3x) を活用
COLOR_COMPLETED='\e[92m'
COLOR_IN_PROGRESS='\e[93m'
COLOR_PENDING=''
COLOR_FAILED='\e[91m'
COLOR_BLOCKED='\e[95m'
COLOR_SHIPPED='\e[96m'
COLOR_ABORTED='\e[91m'
COLOR_RESET='\e[0m'
