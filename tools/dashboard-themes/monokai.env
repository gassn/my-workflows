# monokai テーマ (Monokai 配色、IDE 風、鮮やか)
# 参考: Monokai color palette (Sublime Text / VS Code)
# bold 修飾 (1) + 色の組合せで鮮やかさを表現
COLOR_COMPLETED='\e[1;32m'
COLOR_IN_PROGRESS='\e[1;33m'
COLOR_PENDING=''
COLOR_FAILED='\e[1;31m'
COLOR_BLOCKED='\e[1;35m'
COLOR_SHIPPED='\e[1;36m'
COLOR_ABORTED='\e[1;31m'
COLOR_RESET='\e[0m'
